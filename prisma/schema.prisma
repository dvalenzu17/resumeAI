generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Tier {
  BASIC
  FULL
}

enum JobStatus {
  ANALYZING
  PREVIEW_READY
  PENDING_PAYMENT
  PROCESSING
  COMPLETE
  FAILED
}

model AnalyticsEvent {
  id          String   @id @default(cuid())
  jobId       String?
  event       String
  sessionId   String?
  device      String?
  browser     String?
  os          String?
  country     String?
  utmSource   String?
  utmMedium   String?
  utmCampaign String?
  utmTerm     String?
  utmContent  String?
  referrer    String?
  properties  Json?
  createdAt   DateTime @default(now())

  @@index([event, createdAt])
  @@index([jobId])
  @@index([sessionId])
}

model Job {
  id                String    @id @default(cuid())
  email             String    @default("")
  tier              Tier
  status            JobStatus @default(ANALYZING)
  resumeText        String?
  jobDescription    String
  analysisResult      Json?
  coverLetterContext  Json?
  checkoutSessionId   String?   @unique
  reportUrl         String?
  errorMessage      String?
  previewNudgeSentAt DateTime?
  followUp1SentAt   DateTime?
  followUp2SentAt   DateTime?
  feedbackResult    String?   // 'yes' | 'no'
  tokensInCall1     Int       @default(0)
  tokensOutCall1    Int       @default(0)
  tokensInCall2     Int       @default(0)
  tokensOutCall2    Int       @default(0)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}
