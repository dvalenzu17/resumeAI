generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Tier {
  BASIC
  FULL
}

enum JobStatus {
  ANALYZING
  PREVIEW_READY
  PENDING_PAYMENT
  PROCESSING
  COMPLETE
  FAILED
}

model Job {
  id                String    @id @default(cuid())
  email             String    @default("")
  tier              Tier
  status            JobStatus @default(ANALYZING)
  resumeText        String?
  jobDescription    String
  analysisResult      Json?
  coverLetterContext  Json?
  checkoutSessionId   String?   @unique
  reportUrl         String?
  errorMessage      String?
  followUp1SentAt   DateTime?
  followUp2SentAt   DateTime?
  feedbackResult    String?   // 'yes' | 'no'
  tokensInCall1     Int       @default(0)
  tokensOutCall1    Int       @default(0)
  tokensInCall2     Int       @default(0)
  tokensOutCall2    Int       @default(0)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}
