# Database
DATABASE_URL=postgresql://user:password@host:5432/resumeai

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Lemon Squeezy
LEMONSQUEEZY_API_KEY=
LEMONSQUEEZY_WEBHOOK_SECRET=
LEMONSQUEEZY_STORE_ID=
LEMONSQUEEZY_VARIANT_ID_BASIC=
LEMONSQUEEZY_VARIANT_ID_FULL=

# Resend
RESEND_API_KEY=re_...

# Cloudflare R2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=resumeai-reports

# App
APP_URL=http://localhost:5173
NODE_ENV=development
PORT=3000

# Set to true to skip Claude API calls and return mock data (useful when no credits)
MOCK_CLAUDE=false
